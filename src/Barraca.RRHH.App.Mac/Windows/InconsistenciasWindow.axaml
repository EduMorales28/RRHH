<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Barraca.RRHH.App.Mac.Windows.InconsistenciasWindow"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Title="Inconsistencias detectadas">
  <Grid Margin="14" RowDefinitions="Auto,*,Auto">
    <Border Background="White" Padding="12" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1">
      <StackPanel>
        <TextBlock x:Name="TxtTitulo" FontWeight="Bold" FontSize="18" Foreground="#0F172A"/>
        <TextBlock x:Name="TxtSubtitulo" Margin="0,4,0,0" Foreground="#334155" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" Margin="0,12,0,12" ColumnDefinitions="2*,3*">
      <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" Padding="10">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Refrescar" Click="Refrescar_Click"/>
          </StackPanel>

          <ListBox Grid.Row="1" x:Name="LbErrores" SelectionChanged="Errores_SelectionChanged" ItemsSource="{Binding Errores}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8" Margin="0,0,0,6" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                  <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Tipo}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding NumeroFuncionario}" Foreground="#334155"/>
                    <TextBlock Text="{Binding NombreFuncionario}"/>
                    <TextBlock Text="{Binding Mensaje}" Foreground="#475569" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" Padding="10">
        <Grid RowDefinitions="Auto,Auto,*">
          <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Detalle editable (formato planilla)" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
              <Button Content="Guardar todos" Click="GuardarTodos_Click"/>
            </StackPanel>
          </DockPanel>

          <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" Background="#F8FAFC" Padding="6">
            <Grid ColumnDefinitions="80,70,70,220,170,110,170,120,90">
              <TextBlock Grid.Column="0" Text="Origen" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="ID" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="2" Text="Fila" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="3" Text="Referencia" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="4" Text="Categoría/Tipo" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="5" Text="Monto/Horas" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="6" Text="Observación" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="7" Text="Func. destino" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="8" Text="Acción" FontWeight="SemiBold"/>
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="2">
            <ItemsControl ItemsSource="{Binding Detalles}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#E2E8F0" BorderThickness="1" Padding="6" Margin="0,0,0,6">
                    <Grid ColumnDefinitions="80,70,70,220,170,110,170,120,90">
                      <TextBlock Grid.Column="0" Text="{Binding Origen}" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="1" Text="{Binding RegistroId}" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="2" Text="{Binding FilaOrigen}" VerticalAlignment="Center"/>
                      <TextBlock Grid.Column="3" Text="{Binding Referencia}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                      <TextBox Grid.Column="4" Text="{Binding CategoriaOTipo}"/>
                      <TextBox Grid.Column="5" Text="{Binding MontoOHoras}"/>
                      <TextBox Grid.Column="6" Text="{Binding Observacion}"/>
                      <TextBox Grid.Column="7" Text="{Binding NumeroFuncionarioDestino}" Watermark="Opcional"/>
                      <Button Grid.Column="8" Content="Guardar" Click="GuardarFila_Click"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <DockPanel Grid.Row="2">
      <TextBlock x:Name="TxtEstado" VerticalAlignment="Center" Foreground="#334155"/>
      <Button DockPanel.Dock="Right" Content="Cerrar" Click="Cerrar_Click"/>
    </DockPanel>
  </Grid>
</Window>
