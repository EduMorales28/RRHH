<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Barraca.RRHH.App.Mac.MainWindow"
        Width="1320"
        Height="820"
        MinWidth="980"
        MinHeight="680"
        Icon="avares://Barraca.RRHH.App.Mac/Assets/app-icon.png"
        Title="Barraca RRHH v3 - macOS">
  <Grid RowDefinitions="Auto,*,Auto" Background="#F3F4F6">
    <Border Grid.Row="0" Background="#0B7566" Padding="14">
      <DockPanel LastChildFill="False">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
          <Border Width="64" Height="64" Background="White" CornerRadius="8" Padding="4" Margin="0,0,10,0">
            <Image Source="avares://Barraca.RRHH.App.Mac/Assets/logo-morales.jpeg" Stretch="Uniform" />
          </Border>
          <StackPanel>
            <TextBlock Text="Barraca RRHH v3" Foreground="{DynamicResource BrandTextOnDarkBrush}" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" />
            <TextBlock Text="RRHH + Obras + Costos + Reportes PDF" Foreground="#E4EEF3" Margin="0,2,0,0" />
          </StackPanel>
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Período:" Foreground="{DynamicResource BrandTextOnDarkBrush}" VerticalAlignment="Center" />
          <TextBox Width="120" Text="{Binding Periodo}" Watermark="yyyy-MM" />
          <Button Content="Cambiar período" Command="{Binding CambiarPeriodoCommand}" />
          <Button Content="Refrescar" Command="{Binding RefrescarCommand}" />
          <Button Content="Calcular distribucion" Click="CalcularDistribucionConValidacion_Click" />
          <Button Content="Generar reportes" Click="GenerarReportesConValidacion_Click" />
        </StackPanel>
      </DockPanel>
    </Border>

    <TabControl Grid.Row="1" Margin="16">
      <TabItem Header="Dashboard">
        <ScrollViewer>
          <StackPanel Margin="8" Spacing="12">
            <Grid ColumnDefinitions="*,*,*,*">
              <Border Grid.Column="0" Margin="6" Background="White" CornerRadius="10" Padding="16"><StackPanel><TextBlock Text="Período" Foreground="#6B7280"/><TextBlock Text="{Binding Periodo}" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
              <Border Grid.Column="1" Margin="6" Background="White" CornerRadius="10" Padding="16"><StackPanel><TextBlock Text="Total generado" Foreground="#6B7280"/><TextBlock Text="{Binding TotalGenerado}" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
              <Border Grid.Column="2" Margin="6" Background="White" CornerRadius="10" Padding="16"><StackPanel><TextBlock Text="Adelantos" Foreground="#6B7280"/><TextBlock Text="{Binding Adelantos}" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
              <Border Grid.Column="3" Margin="6" Background="White" CornerRadius="10" Padding="16"><StackPanel><TextBlock Text="Líquidos" Foreground="#6B7280"/><TextBlock Text="{Binding Liquidos}" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            </Grid>

            <Grid ColumnDefinitions="*,*,*,*">
              <Border Grid.Column="0" Margin="6" Background="White" CornerRadius="10" Padding="16"><StackPanel><TextBlock Text="Retenciones" Foreground="#6B7280"/><TextBlock Text="{Binding Retenciones}" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
              <Border Grid.Column="1" Margin="6" Background="White" CornerRadius="10" Padding="16"><StackPanel><TextBlock Text="Funcionarios activos" Foreground="#6B7280"/><TextBlock Text="{Binding FuncionariosActivos}" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
              <Border Grid.Column="2" Margin="6" Background="White" CornerRadius="10" Padding="16"><StackPanel><TextBlock Text="Obras activas" Foreground="#6B7280"/><TextBlock Text="{Binding ObrasActivas}" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
              <Border Grid.Column="3" Margin="6" Background="White" CornerRadius="10" Padding="16"><StackPanel><TextBlock Text="Líneas distribuidas" Foreground="#6B7280"/><TextBlock Text="{Binding LineasDistribuidas}" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
            </Grid>

            <Border Background="White" CornerRadius="10" Margin="6" Padding="16">
              <StackPanel Spacing="6">
                <TextBlock Text="Estado v3" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="• Gestión de período activo"/>
                <TextBlock Text="• Distribución de costos por período"/>
                <TextBlock Text="• Reportes PDF automáticos"/>
                <TextBlock Text="• Motor de datos local SQLite en macOS"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Operaciones">
        <Grid Margin="16" RowDefinitions="Auto,Auto,*" ColumnDefinitions="2*,*">
          <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,14">
            <Button Content="Importar 4 plantillas" Command="{Binding ImportarPlantillasCommand}" Padding="14,8"/>
            <Button Content="Refrescar dashboard" Command="{Binding RefrescarCommand}" Padding="14,8"/>
            <Button Content="Calcular distribución" Click="CalcularDistribucionConValidacion_Click" Padding="14,8"/>
            <Button Content="Generar reportes del período" Click="GenerarReportesConValidacion_Click" Padding="14,8"/>
          </StackPanel>

          <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,12" Background="White" CornerRadius="10" Padding="12">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="180,*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Plantilla Funcionarios" VerticalAlignment="Center"/>
              <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RutaFuncionarios}" Watermark="Ruta .xlsx"/>
              <Button Grid.Row="0" Grid.Column="2" Content="Seleccionar" Click="SeleccionarFuncionarios_Click" Padding="12,6"/>
              <Button Grid.Row="0" Grid.Column="3" Content="Importar" Command="{Binding ImportarFuncionariosCommand}" Padding="12,6"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="Plantilla Obras" VerticalAlignment="Center" Margin="0,8,0,0"/>
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RutaObras}" Margin="0,8,0,0"/>
              <Button Grid.Row="1" Grid.Column="2" Content="Seleccionar" Click="SeleccionarObras_Click" Padding="12,6" Margin="0,8,0,0"/>
              <Button Grid.Row="1" Grid.Column="3" Content="Importar" Command="{Binding ImportarObrasCommand}" Padding="12,6" Margin="0,8,0,0"/>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="Plantilla Horas" VerticalAlignment="Center" Margin="0,8,0,0"/>
              <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RutaHoras}" Margin="0,8,0,0"/>
              <Button Grid.Row="2" Grid.Column="2" Content="Seleccionar" Click="SeleccionarHoras_Click" Padding="12,6" Margin="0,8,0,0"/>
              <Button Grid.Row="2" Grid.Column="3" Content="Importar" Command="{Binding ImportarHorasCommand}" Padding="12,6" Margin="0,8,0,0"/>

              <TextBlock Grid.Row="3" Grid.Column="0" Text="Plantilla Pagos" VerticalAlignment="Center" Margin="0,8,0,0"/>
              <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding RutaPagos}" Margin="0,8,0,0"/>
              <Button Grid.Row="3" Grid.Column="2" Content="Seleccionar" Click="SeleccionarPagos_Click" Padding="12,6" Margin="0,8,0,0"/>
              <Button Grid.Row="3" Grid.Column="3" Content="Importar" Command="{Binding ImportarPagosCommand}" Padding="12,6" Margin="0,8,0,0"/>
            </Grid>
          </Border>

          <Border Grid.Row="2" Grid.Column="0" Margin="0,0,8,0" Background="White" CornerRadius="10" Padding="14">
            <StackPanel Spacing="6">
              <TextBlock Text="Resumen operativo" FontSize="18" FontWeight="SemiBold"/>
              <TextBlock Text="Período" Foreground="#6B7280"/>
              <TextBlock Text="{Binding Periodo}" FontWeight="Bold"/>
              <TextBlock Text="Estado" Foreground="#6B7280" Margin="0,12,0,0"/>
              <TextBlock Text="{Binding Status}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border Grid.Row="2" Grid.Column="1" Margin="8,0,0,0" Background="White" CornerRadius="10" Padding="14">
            <StackPanel Spacing="8">
              <TextBlock Text="Destino de reportes" FontSize="18" FontWeight="SemiBold"/>
              <TextBox Text="{Binding CarpetaReportes}" IsReadOnly="True"/>
              <TextBlock Text="Reportes generados" Margin="0,8,0,0" FontWeight="SemiBold"/>
              <ListBox ItemsSource="{Binding ReportesRecientes}" Height="280"/>
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>

      <TabItem Header="Reportes">
        <Grid Margin="16" RowDefinitions="Auto,*">
          <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,12">
            <Button Content="Generar todos los PDFs" Click="GenerarReportesConValidacion_Click" Padding="16,8"/>
            <Button Content="Refrescar" Command="{Binding RefrescarCommand}" Padding="16,8"/>
          </StackPanel>
          <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="14">
            <StackPanel>
              <TextBlock Text="Archivos generados" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
              <ListBox ItemsSource="{Binding ReportesRecientes}" Height="460"/>
            </StackPanel>
          </Border>
        </Grid>
      </TabItem>
    </TabControl>

    <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8" Padding="10">
      <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
    </Border>
  </Grid>
</Window>
