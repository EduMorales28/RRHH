<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Barraca.RRHH.App.Mac.MainWindow"
        Width="980"
        Height="640"
        MinWidth="840"
        MinHeight="560"
        Title="Barraca RRHH macOS">
  <Grid RowDefinitions="Auto,*,Auto" Margin="16">
    <Border Grid.Row="0" Background="#17324C" CornerRadius="10" Padding="14">
      <DockPanel LastChildFill="False">
        <TextBlock DockPanel.Dock="Left" Text="Barraca RRHH" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center" />
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Periodo" Foreground="White" VerticalAlignment="Center" />
          <TextBox Width="120" Text="{Binding Periodo}" Watermark="yyyy-MM" />
          <Button Content="Refrescar" Command="{Binding RefrescarCommand}" />
          <Button Content="Calcular distribucion" Command="{Binding CalcularDistribucionCommand}" />
          <Button Content="Generar reportes" Command="{Binding GenerarReportesCommand}" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Row="1" Margin="0,14,0,14" ColumnDefinitions="3*,2*" ColumnSpacing="14">
      <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="10" Padding="12">
        <StackPanel Spacing="10">
          <TextBlock Text="Dashboard" FontSize="20" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Total generado" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalGenerado}" HorizontalAlignment="Right" FontWeight="Bold" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Adelantos" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Adelantos}" HorizontalAlignment="Right" FontWeight="Bold" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Liquidos" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Liquidos}" HorizontalAlignment="Right" FontWeight="Bold" />
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Retenciones" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Retenciones}" HorizontalAlignment="Right" FontWeight="Bold" />
          </Grid>

          <Separator />

          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Funcionarios activos" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FuncionariosActivos}" HorizontalAlignment="Right" FontWeight="SemiBold" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Obras activas" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ObrasActivas}" HorizontalAlignment="Right" FontWeight="SemiBold" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Lineas distribuidas" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LineasDistribuidas}" HorizontalAlignment="Right" FontWeight="SemiBold" />
          </Grid>
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Background="#F8FAFC" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="10" Padding="12">
        <StackPanel Spacing="8">
          <TextBlock Text="Reportes generados" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Text="Destino" FontSize="12" Opacity="0.8" />
          <TextBox Text="{Binding CarpetaReportes}" IsReadOnly="True" />
          <ListBox ItemsSource="{Binding ReportesRecientes}" Height="420" />
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="8" Padding="10">
      <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
    </Border>
  </Grid>
</Window>
