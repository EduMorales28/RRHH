<Window x:Class="Barraca.RRHH.App.Windows.ErroresConsistenciaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inconsistencias de horas y pagos" Height="620" Width="1260"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F8FAFC">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" Padding="12" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="txtTitulo" FontWeight="Bold" FontSize="18" Foreground="#0F172A"/>
                <TextBlock x:Name="txtSubtitulo" Margin="0,4,0,0" Foreground="#334155" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <GroupBox Grid.Row="1" Header="Errores detectados" Margin="0,12,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Refrescar" Padding="12,6" Click="Refrescar_Click" Margin="0,0,8,0"/>
                    <Button Content="Corregir seleccionado" Padding="12,6" Click="CorregirSeleccionado_Click" Margin="0,0,8,0"/>
                    <Button Content="Corregir todos con destino cargado" Padding="12,6" Click="CorregirTodos_Click"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="dgErrores" ItemsSource="{Binding Errores}" AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" SelectionUnit="FullRow"
                          SelectionChanged="Errores_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Nro Func." Binding="{Binding NumeroFuncionario}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Nombre" Binding="{Binding NombreFuncionario}" Width="200" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Reg. Horas" Binding="{Binding RegistrosHoras}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Reg. Pagos" Binding="{Binding RegistrosPagos}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Total Horas" Binding="{Binding TotalHoras, StringFormat={}{0:N2}}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Total Pagos" Binding="{Binding TotalPagos, StringFormat={}{0:N2}}" Width="110" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Nro Func. destino (corregir)" Binding="{Binding NumeroFuncionarioDestino, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                        <DataGridTextColumn Header="Detalle" Binding="{Binding Mensaje}" Width="*" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="2" Margin="0,10,0,6" Text="Filas afectadas del error seleccionado" FontWeight="SemiBold" Foreground="#0F172A"/>

                <DataGrid Grid.Row="3" x:Name="dgDetalle" ItemsSource="{Binding Detalles}" AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Origen" Binding="{Binding Origen}" Width="80"/>
                        <DataGridTextColumn Header="Registro ID" Binding="{Binding RegistroId}" Width="90"/>
                        <DataGridTextColumn Header="Fila Excel" Binding="{Binding FilaOrigen}" Width="90"/>
                        <DataGridTextColumn Header="Referencia" Binding="{Binding Referencia}" Width="260"/>
                        <DataGridTextColumn Header="Categoría/Tipo" Binding="{Binding CategoriaOTipo}" Width="180"/>
                        <DataGridTextColumn Header="Horas/Monto" Binding="{Binding MontoOHoras, StringFormat={}{0:N2}}" Width="110"/>
                        <DataGridTextColumn Header="Observación" Binding="{Binding Observacion}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="2">
            <TextBlock x:Name="txtEstado" VerticalAlignment="Center" Foreground="#334155"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Cerrar sin continuar" Padding="14,8" Click="Cancelar_Click" Margin="0,0,8,0"/>
                <Button Content="Continuar" Padding="14,8" Click="Continuar_Click" Background="#0F766E" Foreground="White" FontWeight="SemiBold"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
